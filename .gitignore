###############################################################################
# Large binaries / install media — not source, do not commit
###############################################################################
*.iso
stage3-*.tar.*
*.qcow2
*.qcow2.*

###############################################################################
# QEMU runtime junk (live VM state) — regenerated by the launch scripts
###############################################################################
qemu-run/*.fd                 # OVMF_VARS (writable UEFI nvram)
qemu-run/gentoo-kernel
qemu-run/gentoo-initrd.igz
qemu-run/*.sock               # serial.sock / qmp.sock
qemu-run/*.log                # serial-disk.log, qemu stdout, etc.
qemu-run/*.pid
qemu-run/*.cmd                # vmctl FIFO
qemu-run/guest_known_hosts
qemu-run/etc-portage-current/ # transient export of the guest's /etc/portage

###############################################################################
# Python / editor cruft
###############################################################################
__pycache__/
*.pyc
*~
.DS_Store

###############################################################################
# Heavy raw logs (keep curated artifacts/, drop multi-MB build logs if desired)
###############################################################################
# artifacts/checkpoints/*.log   # uncomment to exclude verbose emerge logs

# live Discord webhook — never commit
.webhook

# local Claude Code settings
.claude/

# live VM runtime dir (canonical copies are in scripts/ & config/)
qemu-run/

# internal state dump (not for public repo)
INTERNAL-STATE.md

#!/usr/bin/env bash
# SSH into the Gentoo QA guest (root). Usage: ./gssh 'command...'   or   ./gssh   (interactive)
cd "$(dirname "$0")"
exec sshpass -p gentooqa ssh -p 2224 \
  -o StrictHostKeyChecking=no \
  -o UserKnownHostsFile="$(pwd)/guest_known_hosts" \
  -o ConnectTimeout=10 \
  -o ServerAliveInterval=30 \
  root@127.0.0.1 "$@"
